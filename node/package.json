{
  "name": "@neuraltrust/trustguard-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the TrustGuard runtime guard API (POST /v1/guard)",
  "license": "MIT",
  "author": "NeuralTrust",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeuralTrust/trustguard-sdk.git",
    "directory": "node"
  },
  "keywords": [
    "neuraltrust",
    "trustguard",
    "guardrails",
    "llm-security",
    "ai-firewall"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
